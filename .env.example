# ── Personalized Gift App — environment ──────────────────────────────────────
# Copy to `.env.local` (gitignored) and fill in as you add backend services.
# Vite only exposes vars prefixed with VITE_ to the browser. Keep SECRETS
# (API keys, signing secrets) on the SERVER only — never VITE_-prefix a secret.

# AI text provider for the builder's copywriting. "mock" (default, offline) or a
# real provider once a backend proxy holds the key. See src/ai/textProvider.js
# and product-plan/04-ai-personalization.md.
VITE_AI_PROVIDER=mock

# ── The following are SERVER-SIDE only (added with the backend, Phase 4+). ────
# They are listed here as a checklist; do NOT prefix with VITE_.

# Payments (India-first) — Razorpay. See product-plan/08-feature-additions.md §2
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# International payments — Stripe (later)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Database + auth (e.g. Supabase / Neon)
# DATABASE_URL=
# AUTH_SECRET=

# Object storage for media (Cloudflare R2, S3-compatible, zero egress)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# Real AI key (server-side; the adapter proxies through your API route)
# ANTHROPIC_API_KEY=

# Transactional email (Resend / Postmark)
# RESEND_API_KEY=
